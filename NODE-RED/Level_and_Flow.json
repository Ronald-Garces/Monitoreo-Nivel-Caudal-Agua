    {
        "id": "fa924b07595ec2da",
        "type": "function",
        "z": "52f15ecb0eb0452e",
        "name": "",
        "func": "// Antes se tenía flow.set(\"fecha\", msg.payload);\nflow.set(\"fecha\", String(msg.payload));      // guarda la fecha completa\n\n// Saca la hora (segunda parte separada por espacio)\nlet s = String(msg.payload);                 // ej: \"21.09.2025 16:36\"\nlet hora = (s.split(\" \")[1] || \"\").trim();   // \"16:36\"\n\n// Si viene sin segundos, añádelos\nif (hora && hora.length === 5) hora = hora + \":00\";  // \"16:36:00\"\n\nflow.set(\"hora\", hora);                      // guarda solo la hora\nreturn msg;\n",
