    {
        "id": "ca4bec77910d1d71",
        "type": "function",
        "z": "52f15ecb0eb0452e",
        "name": "Resetear (limpia charts)",
        "func": "// Marca bandera de reset (si la usas en otra parte)\nflow.set(\"resetear\", true);\n\n// Reinicia estado guardado\nflow.set('savedCount', 0);\nflow.set('nivel_cm', null);\nflow.set('flujov', null);\nflow.set('fecha', null);\nflow.set('hora', null);\nflow.set('savedData', []);\nflow.set('header_written', false);\nflow.set('fileCount', 0);\n\n// Salida 1 -> ui_chart Flujo (limpiar serie)\nconst msgFlujo = { topic: \"Flujo (L/s)\", payload: [] };\n\n// Salida 2 -> ui_chart Nivel (limpiar serie)\nconst msgNivel = { topic: \"Nivel (cm)\",  payload: [] };\n\nreturn [ msgFlujo, msgNivel ];\n",
        "outputs": 2,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
