    {
        "id": "728df4f9db3aaf94",
        "type": "function",
        "z": "52f15ecb0eb0452e",
        "name": "",
        "func": "var bool = flow.get(\"resetear\");\n\nif (bool === true) {\n    var myCount = 0;\n    flow.set('savedCount', myCount);\n    flow.set(\"resetear\", false);   // apaga la bandera\n    // No retornes nada especial aquí; el siguiente dato real empezará en 1\n}\n\n// Si el mensaje trae payload válido, incrementar\nif (msg.payload) {\n    var myCount = flow.get('savedCount') || 0;\n    myCount++;\n    flow.set('savedCount', myCount);\n\n    msg.savedCount = myCount;   // opcional, por si lo usas\n    return msg;\n}\n\nreturn null;\n",
