    {
        "id": "7b7e4b9ef8198ddb",
        "type": "function",
        "z": "52f15ecb0eb0452e",
        "name": "",
        "func": "// Convierte a número\nmsg.payload = msg.payload * 1;\n\n// Nivel en cm\nlet H_cm = msg.payload;\n\n// Convierte a metros\nlet H_m = H_cm / 100;\n\n// L constante (m)\nlet L = 1.8;\n\n// Calcula Q en m³/s\nlet Q_m3s = 1.84 * L * Math.pow(H_m, 1.5);\n\n// Convierte a L/s\nlet Q_lps = Q_m3s * 1000;\n\n// Contador Valor\nlet valor = flow.get(\"valor\") || 0;\nvalor = valor + 1;\nflow.set(\"valor\", valor);\n\n// Guarda en variables de flujo con 1 decimal\nflow.set(\"nivel_cm\", Number(H_cm.toFixed(1)));\nflow.set(\"flujov\",  Number(Q_lps.toFixed(1)));\n\n// Prepara para Google Form (también con 1 decimal)\nmsg.payload1 = valor;\nmsg.payload2 = Number(H_cm.toFixed(1));\nmsg.payload3 = Number(Q_lps.toFixed(1));\n\nreturn msg;\n",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
